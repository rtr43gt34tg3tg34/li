<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin — Liam's Websites</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--ink:#0c0c0b;--white:#fff;--sand:#faf9f7;--border:#e4e1db;--mid:#999690;--dim:#706d68;--blue:#2563eb;--green:#15803d;--red:#dc2626;--r:10px}
    body{font-family:'DM Sans',sans-serif;background:var(--sand);color:var(--ink);height:100svh;display:flex;flex-direction:column;overflow:hidden}

    /* ── LOGIN ── */
    #loginScreen{flex:1;display:flex;align-items:center;justify-content:center}
    .login-card{background:var(--white);border:1px solid var(--border);border-radius:18px;padding:2.5rem;width:100%;max-width:360px;text-align:center}
    .login-card h1{font-size:1.4rem;font-weight:700;margin-bottom:.4rem}
    .login-card p{font-size:.85rem;color:var(--dim);margin-bottom:1.75rem}
    .login-input{width:100%;font-family:'DM Sans',sans-serif;font-size:.9rem;padding:.7rem 1rem;border-radius:var(--r);border:1.5px solid var(--border);outline:none;margin-bottom:.75rem;transition:border-color .15s}
    .login-input:focus{border-color:var(--blue)}
    .login-btn{width:100%;padding:.85rem;border-radius:999px;background:var(--blue);color:var(--white);border:none;font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;transition:background .15s}
    .login-btn:hover{background:#1d4ed8}
    .login-err{color:var(--red);font-size:.82rem;margin-top:.5rem;display:none}

    /* ── MAIN ── */
    #mainScreen{flex:1;display:none;flex-direction:column;overflow:hidden}
    .top-bar{height:52px;background:var(--ink);color:var(--white);display:flex;align-items:center;justify-content:space-between;padding:0 1.25rem;flex-shrink:0}
    .top-bar h2{font-size:.95rem;font-weight:600}
    .top-bar-right{display:flex;align-items:center;gap:.75rem}
    .online-dot{width:8px;height:8px;border-radius:50%;background:#4ade80}
    .top-bar p{font-size:.78rem;opacity:.6}
    .logout-btn{background:none;border:1px solid #333;color:#aaa;font-size:.78rem;padding:.3rem .75rem;border-radius:999px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:border-color .15s}
    .logout-btn:hover{border-color:#888;color:var(--white)}

    .panels{flex:1;display:grid;grid-template-columns:300px 1fr;overflow:hidden}

    /* ── CHAT LIST ── */
    .chat-list-panel{border-right:1px solid var(--border);background:var(--white);display:flex;flex-direction:column;overflow:hidden}
    .chat-list-head{padding:.9rem 1rem;border-bottom:1px solid var(--border);font-size:.8rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--mid)}
    .chat-list-inner{flex:1;overflow-y:auto}
    .chat-item{padding:.9rem 1rem;border-bottom:1px solid var(--border);cursor:pointer;transition:background .12s;position:relative}
    .chat-item:hover{background:var(--sand)}
    .chat-item.active{background:#eef2ff;border-left:3px solid var(--blue)}
    .chat-item-name{font-size:.9rem;font-weight:600;margin-bottom:2px}
    .chat-item-email{font-size:.75rem;color:var(--mid);margin-bottom:3px}
    .chat-item-last{font-size:.78rem;color:var(--dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px}
    .chat-item-badge{position:absolute;top:.9rem;right:.9rem;background:var(--red);color:var(--white);font-size:.65rem;font-weight:700;padding:2px 6px;border-radius:999px}
    .empty-list{padding:2rem 1rem;text-align:center;color:var(--mid);font-size:.85rem}

    /* ── CHAT WINDOW ── */
    .chat-window{display:flex;flex-direction:column;overflow:hidden;background:var(--sand)}
    .chat-win-head{padding:.9rem 1.25rem;background:var(--white);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
    .chat-win-name{font-size:.95rem;font-weight:600}
    .chat-win-email{font-size:.78rem;color:var(--mid);margin-top:1px}
    .no-chat-selected{flex:1;display:flex;align-items:center;justify-content:center;color:var(--mid);font-size:.9rem;flex-direction:column;gap:.5rem}
    .no-chat-selected span{font-size:2.5rem}
    .chat-msgs-area{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.5rem}
    .bubble-wrap{display:flex}
    .bubble-wrap.user{justify-content:flex-start}
    .bubble-wrap.admin{justify-content:flex-end}
    .bubble{max-width:72%;padding:.55rem .85rem;border-radius:14px;font-size:.875rem;line-height:1.5}
    .bubble-wrap.user .bubble{background:var(--white);color:var(--ink);border:1px solid var(--border);border-bottom-left-radius:4px}
    .bubble-wrap.admin .bubble{background:var(--blue);color:var(--white);border-bottom-right-radius:4px}
    .bubble-time{font-size:.65rem;color:var(--mid);margin-top:2px;text-align:center}
    .sys-msg{text-align:center;font-size:.72rem;color:var(--mid);padding:.25rem 0}
    .chat-input-area{padding:.9rem 1.1rem;background:var(--white);border-top:1px solid var(--border);display:flex;gap:.6rem}
    .admin-input{flex:1;font-family:'DM Sans',sans-serif;font-size:.875rem;padding:.6rem .9rem;border-radius:999px;border:1.5px solid var(--border);outline:none;transition:border-color .15s}
    .admin-input:focus{border-color:var(--blue)}
    .admin-send{background:var(--blue);color:var(--white);border:none;border-radius:50%;width:38px;height:38px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;transition:background .15s}
    .admin-send:hover{background:#1d4ed8}

    @media(max-width:700px){
      .panels{grid-template-columns:1fr}
      .chat-list-panel{display:none}
      .chat-list-panel.mobile-show{display:flex;position:fixed;inset:52px 0 0 0;z-index:10}
    }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-card">
    <h1>🔒 Admin Panel</h1>
    <p>Liam's Websites — Support Dashboard</p>
    <input class="login-input" type="password" id="pwInput" placeholder="Enter admin password" onkeydown="if(event.key==='Enter')adminLogin()"/>
    <button class="login-btn" onclick="adminLogin()">Sign In</button>
    <div class="login-err" id="loginErr">Incorrect password. Try again.</div>
  </div>
</div>

<!-- MAIN -->
<div id="mainScreen">
  <div class="top-bar">
    <h2>💬 Support Chats</h2>
    <div class="top-bar-right">
      <div class="online-dot"></div>
      <p>Live</p>
      <button class="logout-btn" onclick="adminLogout()">Log Out</button>
    </div>
  </div>
  <div class="panels">
    <!-- Chat list -->
    <div class="chat-list-panel" id="chatListPanel">
      <div class="chat-list-head">Conversations</div>
      <div class="chat-list-inner" id="chatListInner">
        <div class="empty-list">No chats yet.<br/>They'll appear here when visitors open the chat.</div>
      </div>
    </div>
    <!-- Chat window -->
    <div class="chat-window" id="chatWindow">
      <div class="no-chat-selected" id="noChatSelected"><span>💬</span>Select a conversation</div>
    </div>
  </div>
</div>

<script>
  let ws = null, adminAuthed = false, activeSession = null, chatMetas = {};

  function getWsUrl() {
    return (location.protocol==='https:'?'wss':'ws')+'://'+location.host;
  }

  function adminLogin() {
    const pw = document.getElementById('pwInput').value;
    const err = document.getElementById('loginErr');
    err.style.display = 'none';
    ws = new WebSocket(getWsUrl());
    ws.onopen = () => ws.send(JSON.stringify({ type:'admin_join', password: pw }));
    ws.onmessage = (e) => {
      const msg = JSON.parse(e.data);
      if (msg.type==='auth_fail') { err.style.display='block'; ws.close(); ws=null; return; }
      if (msg.type==='auth_ok') {
        adminAuthed = true;
        document.getElementById('loginScreen').style.display = 'none';
        document.getElementById('mainScreen').style.display  = 'flex';
        renderChatList(msg.chats);
        return;
      }
      if (msg.type==='chat_list')  { renderChatList(msg.chats); return; }
      if (msg.type==='new_msg')    { handleNewMsg(msg); return; }
      if (msg.type==='chat_history') { renderChatHistory(msg); return; }
    };
    ws.onclose = () => { if (adminAuthed) setTimeout(reconnect, 2000); };
    ws.onerror = () => { err.textContent='Connection failed.'; err.style.display='block'; };
  }

  function reconnect() {
    if (!adminAuthed) return;
    // Try restore session — for now just reload
    location.reload();
  }

  function adminLogout() {
    adminAuthed = false;
    if (ws) ws.close();
    document.getElementById('loginScreen').style.display = 'flex';
    document.getElementById('mainScreen').style.display  = 'none';
    document.getElementById('pwInput').value = '';
  }

  function renderChatList(chats) {
    const inner = document.getElementById('chatListInner');
    if (!chats || chats.length===0) {
      inner.innerHTML='<div class="empty-list">No chats yet.<br/>They\'ll appear here when visitors open the chat.</div>'; return;
    }
    chats.forEach(c => chatMetas[c.id] = c);
    inner.innerHTML = chats.map(c => `
      <div class="chat-item ${activeSession===c.id?'active':''}" id="ci_${c.id}" onclick="openChat('${c.id}')">
        <div class="chat-item-name">${esc(c.name)}</div>
        <div class="chat-item-email">${esc(c.email||'No email')}</div>
        <div class="chat-item-last">${c.lastMsg ? esc(c.lastMsg.text) : 'No messages yet'}</div>
        ${c.unread>0 ? `<div class="chat-item-badge">${c.unread}</div>` : ''}
      </div>`).join('');
  }

  function openChat(sid) {
    activeSession = sid;
    // mark active in list
    document.querySelectorAll('.chat-item').forEach(el => el.classList.remove('active'));
    const item = document.getElementById('ci_'+sid);
    if (item) item.classList.add('active');
    ws.send(JSON.stringify({ type:'admin_open', sessionId: sid }));
  }

  function renderChatHistory(msg) {
    const meta = msg.chatMeta || chatMetas[msg.sessionId] || {};
    const win  = document.getElementById('chatWindow');
    win.innerHTML = `
      <div class="chat-win-head">
        <div>
          <div class="chat-win-name">${esc(meta.name||'Visitor')}</div>
          <div class="chat-win-email">${esc(meta.email||'')}</div>
        </div>
      </div>
      <div class="chat-msgs-area" id="msgsArea"></div>
      <div class="chat-input-area">
        <input class="admin-input" id="adminInput" placeholder="Reply to ${esc(meta.name||'visitor')}…" maxlength="500" onkeydown="if(event.key==='Enter')adminSend()"/>
        <button class="admin-send" onclick="adminSend()">➤</button>
      </div>`;
    const area = document.getElementById('msgsArea');
    if (!msg.history || msg.history.length===0) {
      area.innerHTML='<div class="sys-msg">No messages yet</div>';
    } else {
      msg.history.forEach(m => appendAdminBubble(m.from, m.text, m.ts, false));
    }
    area.scrollTop = area.scrollHeight;
    document.getElementById('adminInput')?.focus();
  }

  function handleNewMsg(msg) {
    chatMetas[msg.sessionId] = msg.chatMeta;
    // update list item
    const item = document.getElementById('ci_'+msg.sessionId);
    if (item) {
      item.querySelector('.chat-item-last').textContent = msg.msg.text;
      const badge = item.querySelector('.chat-item-badge');
      if (msg.chatMeta.unread > 0 && msg.sessionId !== activeSession) {
        if (badge) { badge.textContent=msg.chatMeta.unread; }
        else { item.insertAdjacentHTML('beforeend',`<div class="chat-item-badge">${msg.chatMeta.unread}</div>`); }
      } else if (badge) badge.remove();
      // move to top
      const parent = item.parentElement;
      parent.prepend(item);
    } else {
      // new chat — re-render list
      const sorted = Object.values(chatMetas).sort((a,b)=>((b.lastMsg?.ts||0)-(a.lastMsg?.ts||0)));
      renderChatList(sorted);
    }
    // append message if this chat is open
    if (activeSession === msg.sessionId) {
      appendAdminBubble(msg.msg.from, msg.msg.text, msg.msg.ts, true);
    }
  }

  function appendAdminBubble(from, text, ts, scroll) {
    const area = document.getElementById('msgsArea');
    if (!area) return;
    const wrap = document.createElement('div');
    wrap.className='bubble-wrap '+(from==='admin'?'admin':'user');
    const t = ts ? new Date(ts).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}) : '';
    wrap.innerHTML=`<div><div class="bubble">${esc(text)}</div><div class="bubble-time">${from==='admin'?'You':''} ${t}</div></div>`;
    area.appendChild(wrap);
    if (scroll) area.scrollTop=area.scrollHeight;
  }

  function adminSend() {
    const input = document.getElementById('adminInput');
    if (!input) return;
    const text = input.value.trim();
    if (!text || !activeSession || !ws || ws.readyState!==1) return;
    ws.send(JSON.stringify({ type:'admin_msg', sessionId: activeSession, text }));
    input.value='';
  }

  function esc(str) {
    return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
</script>
</body>
</html>
